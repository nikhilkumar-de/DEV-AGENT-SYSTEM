# =============================================================================
# .env.example — Safe template (no real secrets)
# Copy this file to .env and fill in your real values
#   cp .env.example .env
# =============================================================================

# --- GitHub ---
GITHUB_TOKEN=

# --- Team Members + Their Individual Repos ---
# Format: github_username:org_or_username/repo_name
# One entry per person, separated by commas
# Example: TEAM_REPOS=nikhil:nikhil/project-alpha,rahul:rahul/ecommerce-app
TEAM_REPOS=

# --- Email (SMTP) ---
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Scheduler ---
COMMIT_CHECK_HOUR=21
COMMIT_CHECK_MINUTE=0
